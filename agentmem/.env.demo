# AgentMem — demo environment (zero API keys required)
# ─────────────────────────────────────────────────────
# Usage:
# cd agentmem
# cp .env.demo .env
# docker compose up --build
# python scripts/seed_demo.py
#
# This config uses the local hash-projection embedding provider so the
# full demo runs with no Voyage / OpenAI / Anthropic keys.
# DO NOT use these credentials in a production deployment.

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agentmem:agentmem@postgres:5432/agentmem

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Embeddings — local provider, no external API calls ────────────────────
EMBEDDING_PROVIDER=local
EMBEDDING_DIM=1024
VOYAGE_API_KEY=
OPENAI_API_KEY=

# ── Encryption — demo uses zero key (NEVER do this with real data) ────────
# The demo runs without a real key by setting AGENTMEM_ALLOW_UNENCRYPTED=true.
# For production: generate a real key and set it as MASTER_ENCRYPTION_KEY.
# python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
MASTER_ENCRYPTION_KEY=
AGENTMEM_ALLOW_UNENCRYPTED=true

# ── API authentication ────────────────────────────────────────────────────
API_SECRET_SEED=demo-seed-change-before-production

# ── Admin ─────────────────────────────────────────────────────────────────
ADMIN_SECRET=demo-admin-secret

# ── Supersession ──────────────────────────────────────────────────────────
SUPERSESSION_LLM_STAGE=false
SUPERSESSION_REVIEW_THRESHOLD=0.75

# ── Recall hot cache ──────────────────────────────────────────────────────
RECALL_CACHE_ENABLED=true
RECALL_CACHE_TTL_SECONDS=60

# ── Logging — human-readable for demo ────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=false

# ── Rate limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=300

# ── Air-gapped mode ───────────────────────────────────────────────────────
AIRGAP_MODE=false

# ── Background scheduler ─────────────────────────────────────────────────
RETENTION_PRUNE_INTERVAL_HOURS=24.0

# ── Stripe metering — disabled in demo ───────────────────────────────────
STRIPE_API_KEY=

# ── OpenTelemetry — disabled in demo ─────────────────────────────────────
OTEL_SERVICE_NAME=agentmem
OTEL_EXPORTER_OTLP_ENDPOINT=
