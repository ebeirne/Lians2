# AgentMem environment configuration
# Copy this file to .env and fill in values before running docker compose up
#
# cp .env.example .env
#
# NEVER commit .env to source control.

# ── Database ──────────────────────────────────────────────────────────────
# Inside Docker Compose the hostname is the service name ("postgres").
# For local development against a native Postgres, use "localhost".
DATABASE_URL=postgresql+asyncpg://agentmem:agentmem@postgres:5432/agentmem

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Embeddings ────────────────────────────────────────────────────────────
# "sentence-transformers" — self-hosted, no external API calls (recommended
# for regulated / air-gapped deployments).
# Requires: pip install agentmem[local]
# Model is downloaded from HuggingFace on first use
# (~1.3 GB). For fully offline use, pre-download and
# set SENTENCE_TRANSFORMER_MODEL to the local path.
# "voyage"                — Voyage AI finance-tuned model (best accuracy,
# requires VOYAGE_API_KEY, data leaves network)
# "openai"                — OpenAI text-embedding-3-small (dev fallback,
# requires OPENAI_API_KEY, data leaves network)
# "local"                 — deterministic hash-projection for unit tests only
EMBEDDING_PROVIDER=sentence-transformers
SENTENCE_TRANSFORMER_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024
VOYAGE_API_KEY=
OPENAI_API_KEY=

# ── Encryption ────────────────────────────────────────────────────────────
# AES-256-GCM master key — 32 random bytes, base64-encoded.
# REQUIRED — AgentMem will refuse to start without this set.
# Generate:
# python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# For tests/demo only: set AGENTMEM_ALLOW_UNENCRYPTED=true to bypass (never with real data).
MASTER_ENCRYPTION_KEY=

# KMS provider for the master key:
# "env"   — read MASTER_ENCRYPTION_KEY from this file (dev / single-node)
# "aws"   — AWS KMS envelope decryption (requires boto3)
# "azure" — Azure Key Vault Secrets (requires azure-keyvault-secrets)
# "vault" — HashiCorp Vault KV v2 (requires hvac)
KMS_PROVIDER=env

# AWS KMS (KMS_PROVIDER=aws)
# KMS_AWS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/...
# KMS_AWS_REGION=us-east-1
# KMS_AWS_ENCRYPTED_KEY=<base64 CiphertextBlob from aws kms generate-data-key>

# Azure Key Vault (KMS_PROVIDER=azure)
# KMS_AZURE_VAULT_URL=https://myvault.vault.azure.net/
# KMS_AZURE_SECRET_NAME=agentmem-master-key

# HashiCorp Vault (KMS_PROVIDER=vault)
# KMS_VAULT_ADDR=http://127.0.0.1:8200
# KMS_VAULT_TOKEN=
# KMS_VAULT_PATH=agentmem/master-key

# ── API authentication ────────────────────────────────────────────────────
# Seed used to sign API keys — change before any real data is ingested.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_SEED=dev-seed-change-in-production

# ── Admin ────────────────────────────────────────────────────────────────
# Separate admin secret (not an API key) protects /v1/admin/* endpoints.
# Used for provisioning API keys, managing information barriers, and
# configuring retention policies.  MUST be changed in production.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_SECRET=dev-admin-secret-change-in-production

# ── LLM adjudication — Stage 3 supersession (optional) ───────────────────
# Catches paraphrase supersessions that rule-based Stage 2 misses.
# Costs ~$0.00025 per call (Claude Haiku); disabled by default.
ANTHROPIC_API_KEY=
LLM_ADJUDICATION_MODEL=claude-haiku-4-5-20251001
SUPERSESSION_LLM_STAGE=false
# When true, LLM verdicts run off the write path (recommended when enabled)
LLM_ADJUDICATION_ASYNC=true

# ── Domain adapter ────────────────────────────────────────────────────────
# "finance"     — ticker/ISIN/CUSIP normalization; structured keys: ticker,
# metric, entity, isin, cusip, instrument, field.
# Default for quant firms and commercial banks.
# "healthcare"  — ICD-10, NPI, medication name normalization; structured keys:
# patient_id, condition, medication, encounter_id, provider_id,
# procedure_code.  Requires HIPAA BAA before processing real PHI.
# Pair with: AIRGAP_MODE=true, RLS_BARRIERS_ENABLED=true
# "legal"       — matter ID, jurisdiction, claim type normalization; structured
# keys: matter_id, jurisdiction, claim_type, party_id,
# privilege_date, document_type.  Enforces Chinese walls via
# barrier_group=<matter_team_id> on each agent.
# "passthrough" — no normalization; pure semantic supersession only.
# Starting point for custom verticals.
DOMAIN_ADAPTER=finance

# ── Recall hot cache ─────────────────────────────────────────────────────
# Redis is required for the hot cache.  Set RECALL_CACHE_ENABLED=false to
# disable caching and always hit Postgres (useful for debugging).
RECALL_CACHE_ENABLED=true
RECALL_CACHE_TTL_SECONDS=60

# ── Supersession review ───────────────────────────────────────────────────
# Supersessions with confidence below this threshold appear in
# GET /v1/supersessions/review for human review.
SUPERSESSION_REVIEW_THRESHOLD=0.75

# ── Audit chain ───────────────────────────────────────────────────────────
# Merkle-batch mode: batches audit writes for high-throughput deployments.
# Reduces write serialization to one DB row per window.
# Enable for write rates > 100/s; leave false otherwise.
MERKLE_BATCH_ENABLED=false
MERKLE_BATCH_SIZE=64

# ── Information barriers (RLS) ────────────────────────────────────────────
# Enforces information barriers at the PostgreSQL row-level security layer.
# Applied automatically by migration 0011_rls_barriers (alembic upgrade head).
# Enabled by default. Set false only on non-Postgres backends or before
# running the migration on an existing cluster.
RLS_BARRIERS_ENABLED=true

# ── Retention scheduler ───────────────────────────────────────────────────
# Interval (hours) between automated content-prune cycles.
# Set to 0 to disable; requires a retention policy to be set per namespace.
RETENTION_PRUNE_INTERVAL_HOURS=24

# ── Billing (Stripe) ──────────────────────────────────────────────────────
# Usage metering is silently disabled when api_key is empty.
# Configure per-namespace customer IDs via PUT /v1/admin/billing/{namespace}.
STRIPE_API_KEY=
STRIPE_METER_WRITE_EVENT=agentmem_memory_write
STRIPE_METER_RECALL_EVENT=agentmem_memory_recall

# ── Session cache (in-process working set) ────────────────────────────────
SESSION_CACHE_TTL_SECONDS=300
SESSION_CACHE_MAX_ENTRIES=512

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use "*" only for open-access demo instances.
# In production: "https://app.example.com,https://admin.example.com"
CORS_ORIGINS=*

# ── Observability ─────────────────────────────────────────────────────────
METRICS_ENABLED=true
# LOG_JSON=true  → one JSON object per line (Datadog / Splunk / CloudWatch)
# LOG_JSON=false → human-readable format for local development
LOG_LEVEL=INFO
LOG_JSON=true

# ── Rate limiting ─────────────────────────────────────────────────────────
# Per API key, sliding 60-second window backed by Redis.
RATE_LIMIT_PER_MINUTE=300

# ── Air-gapped mode ──────────────────────────────────────────────────────
# Set AIRGAP_MODE=true to guarantee that no customer data leaves the
# deployment boundary.  On startup, AgentMem will hard-fail if:
# • EMBEDDING_PROVIDER is "voyage" or "openai" (external API calls)
# • SUPERSESSION_LLM_STAGE is true (sends content to Anthropic)
#
# Recommended stack for air-gapped deployments:
# AIRGAP_MODE=true
# EMBEDDING_PROVIDER=sentence-transformers
# SENTENCE_TRANSFORMER_MODEL=/opt/models/bge-large-en-v1.5  (pre-downloaded)
# SUPERSESSION_LLM_STAGE=false
AIRGAP_MODE=false

# ── OpenTelemetry (optional) ──────────────────────────────────────────────
# Set OTEL_EXPORTER_OTLP_ENDPOINT to send traces to your observability
# platform (Grafana Tempo, Datadog, Honeycomb, etc.).
OTEL_SERVICE_NAME=agentmem
OTEL_EXPORTER_OTLP_ENDPOINT=
